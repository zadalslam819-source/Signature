#!/bin/bash
# Pre-push hook: runs the same checks as CI before allowing push
# Install: cp scripts/hooks/pre-push .git/hooks/ && chmod +x .git/hooks/pre-push

set -e

# Log file for debugging (visible in VS Code)
LOG_FILE="${GIT_DIR:-.git}/hooks/pre-push.log"
exec > >(tee -a "$LOG_FILE") 2>&1

echo "Running pre-push checks..."
echo "Hook output will be logged to: $LOG_FILE"

echo "→ Checking Rust formatting..."
cargo fmt --all -- --check

echo "→ Running clippy..."
cargo clippy --workspace --all-targets --all-features -- -D warnings -A deprecated

echo "→ Running tests..."
# Ensure dependencies (Redis, Postgres) are running
echo "  → Ensuring dependencies are up..."
if command -v docker &> /dev/null && docker compose -f docker-compose.deps.yml ps | grep -q "Up"; then
    echo "  → Dependencies already running"
else
    echo "  → Starting dependencies..."
    docker compose -f docker-compose.deps.yml up -d --wait || {
        echo "⚠️  Warning: Failed to start dependencies. Tests may fail."
    }
fi

# Set up test database (create and migrate)
echo "  → Setting up test database..."
if command -v sqlx &> /dev/null; then
    TEST_DB_URL="postgres://postgres:password@localhost/keycast_test"
    
    # sqlx database setup creates the database if needed and runs migrations
    if ! sqlx database setup \
        --database-url "$TEST_DB_URL" \
        --source ./database/migrations 2>&1; then
        echo ""
        echo "⚠️  Warning: Failed to set up test database."
        echo "   Troubleshooting steps:"
        echo "   1. Check if Postgres is running:"
        echo "      docker compose -f docker-compose.deps.yml ps"
        echo "   2. Check if another Postgres is using port 5432:"
        echo "      lsof -i :5432"
        echo "   3. Restart dependencies:"
        echo "      docker compose -f docker-compose.deps.yml down && docker compose -f docker-compose.deps.yml up -d"
        echo "   4. Manually create database:"
        echo "      sqlx database create --database-url $TEST_DB_URL"
        echo "      sqlx migrate run --database-url $TEST_DB_URL --source ./database/migrations"
        echo ""
        echo "   Continuing anyway - tests may fail..."
    fi
else
    echo "⚠️  Warning: sqlx not found. Skipping database setup."
    echo "   Install sqlx: cargo install sqlx-cli --no-default-features --features postgres"
fi

# Override DATABASE_URL and REDIS_URL to use local test database/services
DATABASE_URL="postgres://postgres:password@localhost/keycast_test" \
REDIS_URL="redis://localhost:16379" \
TEST_REDIS_URL="redis://localhost:16379" \
cargo test --workspace

echo "→ Building release..."
cargo build --release --workspace

echo "→ Building web app..."
if ! command -v bun &> /dev/null; then
    echo "⚠️  Warning: bun not found. Skipping web build."
    echo "   Install bun: curl -fsSL https://bun.sh/install | bash"
    echo "   Or install mise: curl https://mise.run | sh"
    echo "   Then run: cd web && bun run build"
else
    # Build keycast-login first (dependency of web)
    echo "  → Building keycast-login dependency..."
    cd keycast-login
    bun install
    bun run build
    cd ..
    
    # Now build web app
    cd web
    bun install
    bun run build
    cd ..
fi

echo "✓ All checks passed!"
